# Copy this file to ".env" and fill in real values before going live.
# .env is git-ignored, so your secrets never get committed.

# A long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to 1 only for local development. NEVER enable on a live deployment.
FLASK_DEBUG=0

# Port the app listens on.
PORT=5000

# Optional: override the database location (defaults to local SQLite file).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: create the first admin account non-interactively
# (used by setup_db.py when no terminal input is available, e.g. cloud deploys)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me
# ADMIN_FULL_NAME=Administrator

# ---- Google Drive photo storage (recommended for going live) ----
# Without these, proof-of-delivery photos are saved to local disk instead,
# which is fine for local/manual testing but gets wiped on redeploy on most
# cloud hosts. See the "Google Drive photo storage" section of the README
# for the full setup steps (create a service account, share the Drive
# folder with it, base64-encode the key file).

# The target Drive folder's ID (the string after /folders/ in its URL).
# Defaults to the project's folder if left blank:
# https://drive.google.com/drive/folders/18pKt_-d9igumU2E72tS5VupEYSg0tukF
GOOGLE_DRIVE_FOLDER_ID=18pKt_-d9igumU2E72tS5VupEYSg0tukF

# Base64 of the entire service-account JSON key file. Generate with:
#   base64 -w0 service-account-key.json        (Linux/Mac)
#   certutil -encode service-account-key.json tmp.b64   (Windows, then strip header/footer lines)
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# ---- Google Maps Geocoding API (GPS verification for ID delivery) ----
# Checks a rider's GPS against the resident's address/barangay on delivery
# resolution. Leave blank to skip verification -- GPS is still recorded.
GOOGLE_MAPS_API_KEY=

# If a rider's GPS doesn't match the resident's address/barangay, should the
# "delivered" submission be blocked outright (true) instead of just flagged
# for review (false, default)?
DELIVERY_GPS_HARD_BLOCK=false
